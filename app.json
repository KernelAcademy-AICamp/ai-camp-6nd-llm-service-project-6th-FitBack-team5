{
  "expo": {
    "name": "FItBack",
    "slug": "FItBack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon.png",
    "scheme": "fitback",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/favicon.png",
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "음식 사진을 골라 식단을 기록하기 위해 사진 접근 권한이 필요해요.",
          "cameraPermission": "음식을 촬영해 식단을 기록하기 위해 카메라 권한이 필요해요."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "음식을 촬영해 식단을 기록하기 위해 카메라 권한이 필요해요."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-audio",
      "expo-video",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
