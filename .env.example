# ─────────────────────────────────────────────────────────────────────────
# FitBack 환경변수 (.env.example → .env 로 복사 후 값 채우기)
#
# 팀원은 아래 "① 필수(공유값)"만 채우면 앱이 바로 동작합니다.
# 날씨·경로·지오코딩·대중교통 외부 API는 이미 공유 Supabase Edge Function
# 시크릿(서버)으로 배포돼 있어, 팀원이 개인 키를 만들거나 .env에 넣을 필요가 없습니다.
#   → main을 pull해도, 새 EXPO_PUBLIC_* 키가 추가되지 않는 한 .env를 다시 손댈 필요 없음.
# ─────────────────────────────────────────────────────────────────────────

# ① 필수 — 모든 팀원 (구두로 공유한 동일 값을 그대로 붙여넣기) ───────────────
# Supabase: Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 카카오맵 지도 표시용 JavaScript 키 (클라이언트가 직접 사용).
# 공개 키지만 [플랫폼 키 > JavaScript 키 > JavaScript SDK 도메인]에 http://localhost:8081
# 이 등록돼 있어 등록 도메인에서만 동작합니다. 공유값 사용.
EXPO_PUBLIC_KAKAO_JS_KEY=

# ② 선택 — 개발 편의 ───────────────────────────────────────────────────────
# 로그인 화면 "자동 채우기"용 테스트 계정 (공용 또는 각자).
EXPO_PUBLIC_DEV_TEST_EMAIL=
EXPO_PUBLIC_DEV_TEST_PASSWORD=

# ③ 배포 담당자만 — 일반 팀원 불필요 ──────────────────────────────────────────
# DB 마이그레이션 적용: `npm run db:push` (Node pg). 일반 팀원은 git pull로 코드만 받으면 됨.
# Dashboard → Connect → Session pooler(포트 5432) URI, DB 비밀번호 포함. 특수문자는 percent-encoding.
# EXPO_PUBLIC_ 아님(앱 번들에 절대 포함 금지).
SUPABASE_DB_URL=

# Edge Function 배포: `npx supabase functions deploy <name> --project-ref <ref>`.
# Dashboard → Account → Access Tokens에서 발급(작업 후 폐기 권장).
SUPABASE_ACCESS_TOKEN=

# 홈트 AI 루틴 생성(클라이언트에서 Anthropic 직접 호출) — EXPO_PUBLIC_ 키 필요.
# ⚠️ EXPO_PUBLIC_ 값은 웹/앱 번들에 노출됨(로컬 개발용). 입력 후 dev server 재시작.
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# ④ Edge Function 시크릿 — .env가 아니라 Supabase 서버에 설정 (참고) ──────────
# 아래 키들은 클라이언트 .env가 아니라 supabase secrets로 서버에만 둡니다
# (키 비노출 + 웹 CORS 우회). 이미 공유 프로젝트에 설정·배포돼 있어 팀원은 불필요.
# 재배포·키 교체 시에만, 배포 담당자가 .env에 (EXPO_PUBLIC_ 없이) 아래를 두고:
#   npx supabase secrets set KMA_SERVICE_KEY=... KAKAO_REST_KEY=... ODSAY_API_KEY=... FOOD_SAFETY_API_KEY=... ANTHROPIC_API_KEY=... --project-ref <ref>
#   - KMA_SERVICE_KEY : 기상청 단기예보 Encoding 키 (data.go.kr)
#   - KAKAO_REST_KEY  : 카카오 REST 키 (경로·지오코딩 / 콘솔에서 카카오맵 서비스 ON)
#   - ODSAY_API_KEY   : ODsay 대중교통 키 (lab.odsay.com / 플랫폼 환경 URI에 도메인 등록)
#   - FOOD_SAFETY_API_KEY : 식약처 식품영양성분DB(data.go.kr 15127578) — 식단 검색/분석(food-search)
#   - ANTHROPIC_API_KEY : Claude — 식단 분석/추천/코치 피드백(food-search)
# KMA_SERVICE_KEY=
# KAKAO_REST_KEY=
# ODSAY_API_KEY=
# FOOD_SAFETY_API_KEY=
# ANTHROPIC_API_KEY=
