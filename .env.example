# Supabase
# Get these from https://app.supabase.com → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Dev: auto-login on app start (skip the login screen during development).
# Create a test user in Supabase dashboard with "Auto Confirm User" checked,
# then fill in the credentials here.
EXPO_PUBLIC_DEV_TEST_EMAIL=
EXPO_PUBLIC_DEV_TEST_PASSWORD=

# DB migrations: used by `npm run db:push` to apply supabase/setup.sql (Node pg 패키지).
# Dashboard → Project Settings → Database → Connection string (URI).
# Contains your DB password — keep it only in .env (gitignored), never commit it.
# NOT prefixed with EXPO_PUBLIC_ on purpose: it must never reach the app bundle.
SUPABASE_DB_URL=

# 날씨 (선택): OpenWeather API 키. https://openweathermap.org/api 에서 무료 발급.
# 없으면 센터 이동 화면의 날씨 표시만 생략됩니다(다른 기능엔 영향 없음).
EXPO_PUBLIC_OPENWEATHER_KEY=

# 경로 (선택): 카카오모빌리티 길찾기. https://developers.kakao.com 앱 → REST API 키.
# 없으면 센터 이동 화면의 경로 표시만 생략됩니다.
EXPO_PUBLIC_KAKAO_REST_KEY=
